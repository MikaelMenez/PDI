import { Button, ScrollView } from "std-widgets.slint";

export struct ImagemSaida {
    img: image,
    legenda: string,
}

export component AppWindow inherits Window {
    title: "Processador de Imagens Digitais (PDI) - UFPB";
    min-width: 1024px;
    min-height: 768px;
    background: #1e1e2e;

    // ------------------------------------------------------------------------
    // PROPRIEDADES DE ESTADO E NOTIFICAÇÃO
    // ------------------------------------------------------------------------
    in-out property <image> img_entrada;
    in-out property <[ImagemSaida]> lista_saidas: [];
    in-out property <int> indice_selecionado: 0;
    in-out property <string> processo_atual: "Nenhum";

    in-out property <string> status_texto: "Sistema pronto. Aguardando ação...";
    in-out property <brush> status_cor: #a6adc8;

    private property <[string]> filtros: [
        "Decomposição RGB",
        "Decomposição HSV",
        "Limiarização",
        "Transf. Logarítmica",
        "Transf. de Potência (Gamma)",
        "Equalização de Histograma",
        "Fatiamento por Intensidade",
        "Filtro de Média Gaussiana",
        "Filtro de Mediana",
        "Filtro de Mínimo",
        "Filtro de Máximo",
        "Máscara de Aguçamento",
        "Realce por Laplaciano",
        "Gradiente de Sobel",
        "Passa-Baixa Gaussiano",
        "Passa-Alta Gaussiano",
        "Passa-Baixa Butterworth",
        "Passa-Alta Butterworth",
        "Filtro Adaptativo de Mediana",
        "Ruído Aditivo Gaussiano",
        "Ruído Sal",
        "Ruído Pimenta",
        "Ruído Sal e Pimenta"
    ];

    callback abrir_arquivo();
    callback selecionar_processo(int, string);
    callback executar_processo();
    callback salvar_atual();
    callback salvar_todas();

    VerticalLayout {
        HorizontalLayout {
            padding: 16px;
            spacing: 16px;

            // ====================================================================
            // PAINEL LATERAL DE CONTROLE (Esquerda)
            // ====================================================================
            Rectangle {
                width: 320px;
                background: #252538;
                border-radius: 8px;

                VerticalLayout {
                    padding: 14px;
                    spacing: 12px;

                    Button {
                        text: "📂 Abrir Imagem";
                        clicked => {
                            root.abrir_arquivo();
                        }
                    }

                    Rectangle {
                        height: 45px;
                        background: #11111b;
                        border-radius: 4px;
                        Text {
                            text: "Filtro: " + root.processo_atual;
                            color: #cdd6f4;
                            font-size: 14px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }

                    Text {
                        text: "Selecione o Algoritmo:";
                        color: #a6adc8;
                        font-size: 12px;
                    }

                    ScrollView {
                        VerticalLayout {
                            spacing: 4px;
                            for filtro[i] in root.filtros: Rectangle {
                                height: 35px;
                                background: root.processo_atual == filtro ? #45475a : #1e1e2e;
                                border-radius: 4px;

                                TouchArea {
                                    clicked => {
                                        root.selecionar_processo(i, filtro);
                                    }
                                }

                                Text {
                                    text: filtro;
                                    color: root.processo_atual == filtro ? #f5c2e7 : #cdd6f4;
                                    x: 10px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Button {
                        text: "⚡ Executar Processo";
                        primary: true;
                        enabled: root.processo_atual != "Nenhum";
                        clicked => {
                            root.executar_processo();
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        height: 40px;

                        Button {
                            text: "💾 Salvar Atual";
                            enabled: root.lista_saidas.length > 0;
                            clicked => {
                                root.salvar_atual();
                            }
                        }

                        Button {
                            text: "📦 Salvar Todas";
                            enabled: root.lista_saidas.length > 0;
                            clicked => {
                                root.salvar_todas();
                            }
                        }
                    }
                }
            }

            // ====================================================================
            // ÁREA DE VISUALIZAÇÃO DAS MATRIZES (Direita) - AGORA ADAPTÁVEL
            // ====================================================================
            VerticalLayout {
                spacing: 16px;
                // Faz com que toda a área da direita estique para preencher o tamanho da janela
                vertical-stretch: 1;

                HorizontalLayout {
                    spacing: 16px;
                    vertical-stretch: 1;

                    // 🟦 CONTAINER DE ENTRADA (AZUL)
                    VerticalLayout {
                        spacing: 6px;
                        vertical-stretch: 1;
                        Text {
                            text: "IMAGEM DE ENTRADA (ORIGINAL)";
                            color: #89b4fa;
                            font-weight: 700;
                        }

                        Rectangle {
                            min-height: 300px;   // Evita colapsar se a janela for muito reduzida
                            vertical-stretch: 1; // 👈 Estica dinamicamente baseado no monitor/resolução
                            background: #11111b;
                            border-width: 2px;
                            border-color: #89b4fa;
                            border-radius: 8px;
                            clip: true;

                            Image {
                                source: root.img_entrada;
                                width: 100%;
                                height: 100%;
                                image-fit: contain; // Adapta a proporção interna da imagem sem esticar os pixels
                            }
                        }

                        Text {
                            text: " ";
                            font-size: 14px;
                        }
                    }

                    // 🟥 CONTAINER DE SAÍDA REATIVO (VERMELHO)
                    VerticalLayout {
                        spacing: 6px;
                        vertical-stretch: 1;
                        Text {
                            text: "PRODUTO DO PROCESSAMENTO (SAÍDA)";
                            color: #f38ba8;
                            font-weight: 700;
                        }

                        Rectangle {
                            min-height: 300px;   // Seguro contra colapsos estruturais
                            vertical-stretch: 1; // 👈 Acompanha simetricamente o painel azul
                            background: #11111b;
                            border-width: 2px;
                            border-color: #f38ba8;
                            border-radius: 8px;
                            clip: true;

                            if root.lista_saidas.length > 0: Image {
                                source: root.lista_saidas[root.indice_selecionado].img;
                                width: 100%;
                                height: 100%;
                                image-fit: contain;
                            }

                            if root.lista_saidas.length == 0: Text {
                                text: "Aguardando execução de algum algoritmo...";
                                color: #585b70;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }

                        if root.lista_saidas.length > 0: Text {
                            text: root.lista_saidas[root.indice_selecionado].legenda;
                            color: #a6adc8;
                            font-size: 14px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        if root.lista_saidas.length == 0: Text {
                            text: "Nenhum processamento ativo";
                            color: #585b70;
                            font-size: 14px;
                            horizontal-alignment: center;
                        }
                    }
                }

                // CONTROLES DE NAVEGAÇÃO MULTI-SAÍDA
                if root.lista_saidas.length > 1: HorizontalLayout {
                    alignment: center;

                    Rectangle {
                        height: 50px;
                        background: #252538;
                        border-radius: 8px;
                        width: 400px;

                        HorizontalLayout {
                            padding: 8px;
                            spacing: 20px;
                            alignment: center;

                            Button {
                                text: "◀ Anterior";
                                enabled: root.indice_selecionado > 0;
                                clicked => {
                                    root.indice_selecionado -= 1;
                                }
                            }

                            Text {
                                text: (root.indice_selecionado + 1) + " / " + root.lista_saidas.length;
                                color: #cdd6f4;
                                font-size: 14px;
                                vertical-alignment: center;
                            }

                            Button {
                                text: "Próxima ▶";
                                enabled: root.indice_selecionado < root.lista_saidas.length - 1;
                                clicked => {
                                    root.indice_selecionado += 1;
                                }
                            }
                        }
                    }
                }
            }
        }

        // ====================================================================
        // BARRA DE STATUS DINÂMICA
        // ====================================================================
        Rectangle {
            height: 32px;
            background: #11111b;

            Text {
                text: root.status_texto;
                color: root.status_cor;
                x: 16px;
                vertical-alignment: center;
                font-size: 13px;
                font-weight: 600;
            }
        }
    }
}
